CKAN_DB_USER=ckan
CKAN_DB_PASSWORD=change-me-db-password
CKAN_DB_NAME=ckan
CKAN_DATASTORE_READ_USER=datastore_ro
CKAN_DATASTORE_READ_PASSWORD=change-me-datastore-password
CKAN_SECRET_KEY=change-me-ckan-secret-key
CKAN_BEAKER_SESSION_SECRET=change-me-beaker-session-secret
CKAN_BEAKER_SESSION_VALIDATE_KEY=change-me-beaker-validate-secret
CKAN_SYSADMIN_NAME=vigancity_admin
CKAN_SYSADMIN_PASSWORD=change-me-admin-password
CKAN_SYSADMIN_EMAIL=admin@vigan.gov.ph
CKAN_SITE_URL=http://172.16.2.11:8080
CKAN_SITE_TITLE=Vigan City Open Data Portal
CKAN_SITE_DESCRIPTION=Official open data portal of the City Government of Vigan
NEXT_PUBLIC_CKAN_URL=http://nginx
NEXT_PUBLIC_SITE_URL=http://172.16.2.11:8080

# Preferred: store only the SHA-256 hash of a long random access token.
# Generate a token and hash with:
#   node -e "const crypto=require('crypto');const token=crypto.randomBytes(32).toString('base64url');console.log('LOGIN_ACCESS_TOKEN='+token);console.log('LOGIN_ACCESS_TOKEN_HASH='+crypto.createHash('sha256').update(token).digest('hex'))"
LOGIN_ACCESS_TOKEN_HASH=change-me-sha256-token-hash
# Backward-compatible fallback if LOGIN_ACCESS_TOKEN_HASH is not set.
# LOGIN_ACCESS_TOKEN=change-me-long-random-login-access-token
# CKAN email / user invites
# Local default: docker-compose Mailpit service, web UI at http://localhost:8025
CKAN_SMTP_SERVER=mailpit:1025
CKAN_SMTP_STARTTLS=false
CKAN_SMTP_USER=
CKAN_SMTP_PASSWORD=
CKAN_SMTP_MAIL_FROM=portal@vigan.gov.ph
CKAN_ERROR_EMAIL_FROM=portal@vigan.gov.ph
CKAN_EMAIL_TO=admin@vigan.gov.ph

# CKAN account creation
CKAN_CREATE_USER_VIA_WEB=true
CKAN_CREATE_USER_VIA_API=false
